# Sao chép file này thành .env rồi chỉnh nếu cần: cp .env.example .env
# Giá trị mặc định đã khớp với docker-compose.yml nên thường không cần sửa.

SECRET_KEY=django-insecure-dev-key-doi-truoc-khi-public
DEBUG=True

# Kết nối tới PostgreSQL trong Docker
DB_NAME=classroom_management
DB_USER=classroom_management
DB_PASSWORD=classroom_management_pass
DB_HOST=127.0.0.1
DB_PORT=5432
